алг стены нач
цел лучи = 100 | потом заменить на шир листа
вещ шаглуча, начугол = 0, уголлуча
вещ раст, граст = 0, враст = 0, нраст, свыс
вещ ptx, pty, dptx, dpty
шаглуча := ПИ/лучи/1.5 |угол обзора вместо двапи
начугол := pdir-угол обзора/2
уголлуча := начугол 
ptx := int(px)
pty := int(py)
если px = ptx то px := px+0.0001 всё
если py = pty то py := py+0.0001 всё
вещ rx, ry, ox, oy, dirx, diry, hx=0, hy=0, vx=0, vy=0
вещ atg, ntg
цел x
нц для x от 1 до лучи
dirx := cos(уголлуча)
diry := sin(уголлуча)
| перо(1, жёлтый)
| линия(int(px*К), int(py*К), int((px+dirx*10)*К), int((py+diry*10)*К))
atg := 0
ntg := 0
если не уголлуча = 0 то 
atg := -dirx/diry
всё
если не уголлуча = 0 то 
ntg := -diry/dirx
всё
| Горизонтальные
граст := 0
выбор
при diry < 0: ry := pty+1; rx := px+(py-ry)*atg; oy := 1; ox := -oy*atg
при diry > 0: ry := pty-0.002; rx := px+(py-ry)*atg; oy := -1; ox := -oy*atg
иначе rx := px; ry := py; граст := -1
всё
если не граст = -1 то
бросить луч(rx, ry, ox, oy, граст, hx, hy)
всё
| Вертикальные
враст := 0
выбор
при dirx < 0: rx := ptx+1; ry := py+(px-rx)*ntg; ox := 1; oy := -ox*ntg
при dirx > 0: rx := ptx-0.002; ry := py+(px-rx)*ntg; ox := -1; oy := -ox*ntg
иначе rx := px; ry := py; враст := -1
всё
если не враст = -1 то
бросить луч(rx, ry, ox, oy, враст, vx, vy)
всё
если не враст = -1 и враст < граст или граст = -1 то
раст := враст
rx := vx
ry := vy
иначе
раст := граст
rx := hx
ry := hy
всё
перо(1, красный)
линия(int(px*К), int(py*К), int(rx*К), int(ry*К))
|перо(1, чёрный)
|линия(x, 0, x, int(пол высоты-свыс))
|линия(x, высота листа, x, int(пол высоты+свыс))  
|перо(1, RGB(255, 255, 255))
|линия(x, int(пол высоты-свыс), x, int(пол высоты+свыс))
уголлуча := уголлуча+шаглуча
кц
кон

